# ── Stripe ────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local dev, and add the same variables in
# Vercel → Project → Settings → Environment Variables for production.
#
# REQUIRED for checkout. Server-side only — keep it SECRET, never commit it.
# Get it at https://dashboard.stripe.com/apikeys  (it starts with sk_live_ ...)
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Publishable key (safe to expose to the browser). Optional for the current
# redirect-based checkout flow, but handy if you add Stripe.js later.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
